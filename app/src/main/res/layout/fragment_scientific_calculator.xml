<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#0F0F1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">
        <Button
            android:id="@+id/btnDegRad"
            android:text="DEG"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#33334D"
            android:textColor="#FF6B35"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="#888888"
        android:textSize="16sp"
        android:minHeight="24dp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:layout_marginBottom="8dp"
        android:text="0"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="5"
        android:rowCount="7">

        <Button android:id="@+id/btnSin" android:text="sin" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnCos" android:text="cos" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnTan" android:text="tan" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnLog" android:text="log" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnLn" android:text="ln" style="@style/CalcFnButton"/>

        <Button android:id="@+id/btnSinh" android:text="sinh" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnCosh" android:text="cosh" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnTanh" android:text="tanh" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnSqrt" android:text="√" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnPow" android:text="^" style="@style/CalcFnButton"/>

        <Button android:id="@+id/btnPi" android:text="π" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnE" android:text="e" style="@style/CalcFnButton"/>
        <Button android:id="@+id/btnParenOpen" android:text="(" style="@style/CalcOpButton"/>
        <Button android:id="@+id/btnParenClose" android:text=")" style="@style/CalcOpButton"/>
        <Button android:id="@+id/btnClear" android:text="C" style="@style/CalcOpButton"/>

        <Button android:id="@+id/btn7" android:text="7" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn8" android:text="8" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn9" android:text="9" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btnDivide" android:text="÷" style="@style/CalcOpButton"/>
        <Button android:id="@+id/btnDelete" android:text="⌫" style="@style/CalcOpButton"/>

        <Button android:id="@+id/btn4" android:text="4" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn5" android:text="5" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn6" android:text="6" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btnMultiply" android:text="×" style="@style/CalcOpButton"/>
        <Button android:id="@+id/btnMinus" android:text="−" style="@style/CalcOpButton"/>

        <Button android:id="@+id/btn1" android:text="1" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn2" android:text="2" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btn3" android:text="3" style="@style/CalcNumButton"/>
        <Button android:id="@+id/btnPlus" android:text="+" style="@style/CalcOpButton"/>
        <Button android:id="@+id/btnEquals" android:text="=" style="@style/CalcEqualsButton"
            android:layout_rowSpan="2"/>

        <Button android:id="@+id/btn0" android:text="0" style="@style/CalcNumButton"
            android:layout_columnSpan="2"/>
        <Button android:id="@+id/btnDot" android:text="." style="@style/CalcNumButton"/>
        <Button android:id="@+id/btnAbs" android:text="|x|" style="@style/CalcFnButton"/>

    </GridLayout>

</LinearLayout>
