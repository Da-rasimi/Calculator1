<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1E">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:text="Permutations &amp; Combinations"
        android:textColor="#FF6B35"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etN"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="n"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:inputType="number"/>

        <EditText
            android:id="@+id/etR"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:hint="r"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:inputType="number"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnPermutation"
            android:text="nPr"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:backgroundTint="#33334D"
            android:textColor="#FF6B35"/>

        <Button
            android:id="@+id/btnCombination"
            android:text="nCr"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#33334D"
            android:textColor="#FF6B35"/>

        <Button
            android:id="@+id/btnFactorial"
            android:text="n!"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#33334D"
            android:textColor="#FF6B35"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvCombinatoricsResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:text="—"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222244"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:text="Statistics"
        android:textColor="#FF6B35"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etDataSet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter numbers separated by commas, e.g. 4, 8, 15, 16, 23, 42"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:inputType="textMultiLine"
        android:minLines="2"/>

    <Button
        android:id="@+id/btnComputeStats"
        android:text="Compute Statistics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF6B35"
        android:textColor="#FFFFFF"/>

    <TextView
        android:id="@+id/tvStatsResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:textSize="15sp"
        android:layout_marginTop="12dp"/>

</LinearLayout>
</ScrollView>
